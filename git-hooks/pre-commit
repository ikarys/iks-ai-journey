#!/usr/bin/env bash
#
# pre-commit hook — secret scanning with gitleaks (best-effort).
#
# Tool-agnostic: wired via `core.hooksPath=git-hooks` (see bootstrap.sh).
#
# Behaviour:
#   * If gitleaks is installed, scan the staged changes and BLOCK the commit on a
#     finding (exit 1).
#   * If gitleaks is not installed, print a warning and allow the commit (exit 0)
#     so the workflow is never hard-broken by a missing optional tool.

set -u

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "⚠ gitleaks not installed — skipping secret scan." >&2
  echo "  Install it (https://github.com/gitleaks/gitleaks) for pre-commit protection." >&2
  exit 0
fi

# Scan only what is staged for this commit.
if gitleaks protect --staged --redact --no-banner; then
  exit 0
else
  echo "✖ gitleaks detected a potential secret in the staged changes." >&2
  echo "  Remove it or, if it is a false positive, configure a .gitleaks.toml allowlist." >&2
  exit 1
fi
