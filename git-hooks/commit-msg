#!/usr/bin/env bash
#
# commit-msg hook — enforce Conventional Commits.
#
# Tool-agnostic: this runs for any git client (CLI, IDE, an AI agent that commits),
# because it is wired via `core.hooksPath=git-hooks` (see bootstrap.sh).
#
# Accepted format:
#   type(optional-scope)!: subject
#   e.g.  feat(api): add pagination
#         fix!: drop deprecated field
#         docs: fix typo in README
#
# Merge/revert/fixup commits are allowed through.

set -u

msg_file="$1"
header="$(head -n1 "$msg_file")"

# Let git's own machinery through.
case "$header" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*)
    exit 0
    ;;
esac

types='feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert'
pattern="^(${types})(\([a-z0-9._-]+\))?(!)?: .+"

if printf '%s' "$header" | grep -Eq "$pattern"; then
  exit 0
fi

cat >&2 <<EOF
✖ Commit message does not follow Conventional Commits.

  Got:      $header

  Expected: <type>(<scope>)?: <subject>
  Types:    ${types//|/, }

  Examples: feat(parser): support nested arrays
            fix(auth)!: reject expired tokens
            docs: clarify setup steps
EOF
exit 1
